                  "src": "{{imageFilePath}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/media/upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "media",
                "upload"
              ]
            },
            "description": "Upload anh. Neu Postman khong resolve duoc bien `imageFilePath` cho file, mo request va chon lai file bang tay."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
